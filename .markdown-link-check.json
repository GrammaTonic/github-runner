{
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "10s",
  "timeout": "15s",
  "httpHeaders": [
    {
      "urls": ["https://github.com", "https://api.github.com"],
      "headers": {
        "Accept": "text/html"
      }
    }
  ],
  "aliveStatusCodes": [200, 206, 301, 302],
  "ignorePatterns": [
    {
      "pattern": "^https://github\\.com/.*/actions/runs/"
    },
    {
      "pattern": "^https://github\\.com/.*/settings/"
    },
    {
      "pattern": "^https://github\\.com/.*/wiki/"
    },
    {
      "pattern": "^#"
    }
  ]
}
